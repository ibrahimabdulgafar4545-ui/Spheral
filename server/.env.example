PORT=5000
MONGODB_URI=mongodb://localhost:27017/spheral
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=90d
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Brevo (Sendinblue) Email SMTP Key
BREVO_API_KEY=        # Get from https://app.brevo.com/
BREVO_SENDER_EMAIL=   # Your verified sender email
BREVO_SENDER_NAME=Spheral Support

# Deezer API (via RapidAPI for Reels/Stories music search)
# Get from https://rapidapi.com/deezerdevs/api/deezer-1
RAPIDAPI_KEY=YOUR_RAPIDAPI_KEY_HERE
# Agora RTC (Optional: required only if using Agora backend instead of our native WebRTC)
# Get from https://console.agora.io/ (Select Testing Mode: App ID only)
AGORA_APP_ID=

# Groq API Key (Required for AI assistant and AI song suggestions)
# Generate a free key from https://console.groq.com/
GROQ_API_KEY=
